# Streamlit Cloud Secrets Template
# In Streamlit Cloud: Settings → Secrets → paste contents (without .example extension)
# For local dev: copy to .streamlit/secrets.toml (already gitignored)

# API Keys (optional for DEV version)
FINANCIAL_API_KEY = "your_financial_api_key_here"
NEWS_API_KEY = "your_news_api_key_here"
OPENAI_API_KEY = "your_openai_api_key_here"

# App settings
ENVIRONMENT = "development"
